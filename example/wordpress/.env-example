# Copy this file to .env and update the values before running `docker compose up`.

# Database passwords
MYSQL_ROOT_PASSWORD=change-me
MYSQL_PASSWORD=change-me

# Initial admin account created by civicrm-docker-install
CIVICRM_ADMIN_USER=admin
CIVICRM_ADMIN_PASS=change-me
CIVICRM_ADMIN_EMAIL=admin@example.com
